# OpenClaw 中转插件配置
# 复制此文件为 .env 并填入实际配置

# ===================
# 服务器配置
# ===================

# 中转服务器地址（WebSocket）
# 开发环境: ws://localhost:8080
# 生产环境: wss://your-server.com
RELAY_SERVER_URL=ws://localhost:8080

# ===================
# 认证配置
# ===================

# API Key（从服务器管理后台获取）
# 示例: oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_KEY=your_api_key_here

# ===================
# 设备配置
# ===================

# 设备 ID（唯一标识，不填则自动生成）
# DEVICE_ID=claw-desktop-001

# 设备名称（显示名称）
DEVICE_NAME=OpenClaw 本地设备

# ===================
# 日志配置
# ===================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 日志文件路径（可选）
# LOG_FILE=logs/plugin.log
